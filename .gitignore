# Ignore everything by default
*

# Un-ignore directories (the leading ! means "do not ignore")
!python-refresher/
!python-refresher/**

!rag-pdf-project/
!rag-pdf-project/**

!rag-multi-agent/
!rag-multi-agent/**

# Un-ignore this .gitignore itself
!.gitignore

# Re-ignore artifacts that should never be committed
**/.DS_Store
**/__pycache__/
**/*.pyc
**/*.pyo
**/.claude/
**/faiss_index/
**/chroma_db/
**/.chroma/
**/*.zip
**/.env
**/.venv/
